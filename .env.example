# Toggle the dark hillshade terrain layer on top of the CARTO Dark Matter base.
# Set to "false" for the flat-base comparison view. Defaults to true.
VITE_HILLSHADE_ENABLED=true

# -----------------------------------------------------------------------------
# Regional Context layer — API keys for the data fetchers under scripts/.
# All free signups. The fetchers gracefully skip any agency whose key is unset
# — the resulting topic JSONs simply have null blocks at that level.
# -----------------------------------------------------------------------------

# https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# https://data.bls.gov/registrationEngine/ — optional but raises 25→500 queries/day
BLS_API_KEY=

# https://apps.bea.gov/API/signup/
BEA_API_KEY=

# https://www.huduser.gov/portal/dataset/fmr-api.html (bearer token)
HUD_API_TOKEN=

# https://data.colorado.gov/profile/app_tokens — optional, raises rate limits
SOCRATA_APP_TOKEN=
